{
  "juego": "zona_impacto",
  "metadata": {
    "descripcion": "Zona de Impacto - Regla de Signos",
    "mecanica": "Determiná el signo y el resultado de las operaciones con números enteros."
  },
  "ejercicios": [
    { "id": 1, "curso_minimo": "1ro", "tipo": "multiplicacion", "expresion": "(-3) × (+4)", "valor": -12, "signo": "-", "dificultad": 1, "explicacion": "Negativo por positivo da negativo." },
    { "id": 2, "curso_minimo": "1ro", "tipo": "division", "expresion": "(-15) ÷ (-3)", "valor": 5, "signo": "+", "dificultad": 1, "explicacion": "Negativo dividido negativo da positivo." },
    { "id": 3, "curso_minimo": "1ro", "tipo": "multiplicacion", "expresion": "(+6) × (-2)", "valor": -12, "signo": "-", "dificultad": 1, "explicacion": "Positivo por negativo da negativo." },
    { "id": 4, "curso_minimo": "2do", "tipo": "potencia", "expresion": "(-2)³", "valor": -8, "signo": "-", "dificultad": 2, "explicacion": "Base negativa con exponente impar da resultado negativo." },
    { "id": 5, "curso_minimo": "2do", "tipo": "potencia", "expresion": "(-5)²", "valor": 25, "signo": "+", "dificultad": 2, "explicacion": "Base negativa con exponente par da resultado positivo." },
    { "id": 6, "curso_minimo": "2do", "tipo": "multiplicacion", "expresion": "(-4) × (-3)", "valor": 12, "signo": "+", "dificultad": 2, "explicacion": "Menos por menos es más." },
    { "id": 7, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(16)", "valor": 4, "signo": "+", "dificultad": 3, "opciones": ["4", "-4", "8", "No real"], "explicacion": "La raíz cuadrada de un positivo es positiva." },
    { "id": 8, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(-9)", "valor": null, "signo": "invalido", "dificultad": 3, "opciones": ["3", "-3", "0", "No real"], "explicacion": "La raíz de un número negativo no es un número real en ℝ." },
    { "id": 9, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "(-2)³ × (-3)", "valor": 24, "signo": "+", "dificultad": 3, "opciones": ["24", "-24", "-6", "18"], "explicacion": "(-8) × (-3) = 24. Menos por menos es más." },
    { "id": 10, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "(-3)² × (-2)", "valor": -18, "signo": "-", "dificultad": 3, "opciones": ["18", "-18", "-12", "6"], "explicacion": "(-3)² es 9. 9 × (-2) = -18. Positivo por negativo da negativo." },
    { "id": 11, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "(-1)⁹ × (-5)²", "valor": -25, "signo": "-", "dificultad": 3, "opciones": ["25", "-25", "1", "-1"], "explicacion": "(-1)⁹ es -1. (-5)² es 25. -1 × 25 = -25." },
    { "id": 12, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "(-2)² × (-2)³", "valor": -32, "signo": "-", "dificultad": 3, "opciones": ["32", "-32", "16", "-16"], "explicacion": "4 × (-8) = -32. Más por menos es menos." },
    { "id": 13, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "(-5)² × (-2)", "valor": -50, "signo": "-", "dificultad": 3, "opciones": ["50", "-50", "-20", "20"], "explicacion": "25 × (-2) = -50. El cuadrado de un negativo siempre es positivo." },
    { "id": 14, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "(-2)⁴ × (-1)¹⁰", "valor": 16, "signo": "+", "dificultad": 3, "opciones": ["16", "-16", "8", "-8"], "explicacion": "16 × 1 = 16. Ambos factores terminan siendo positivos por tener exponentes pares." },
    { "id": 15, "curso_minimo": "2do", "tipo": "division_potencia", "expresion": "(-8)² ÷ (+4)", "valor": 16, "signo": "+", "dificultad": 2, "explicacion": "(-8)² es 64. 64 ÷ 4 = 16. Positivo dividido positivo es positivo." },
    { "id": 16, "curso_minimo": "2do", "tipo": "division_potencia", "expresion": "(-27) ÷ (-3)²", "valor": -3, "signo": "-", "dificultad": 2, "explicacion": "(-3)² es 9. -27 ÷ 9 = -3. Negativo dividido positivo es negativo." },
    { "id": 17, "curso_minimo": "2do", "tipo": "division_potencia", "expresion": "(-2)³ ÷ (-2)", "valor": 4, "signo": "+", "dificultad": 2, "explicacion": "(-2)³ es -8. -8 ÷ -2 = 4. Negativo dividido negativo es positivo." },
    { "id": 18, "curso_minimo": "2do", "tipo": "division_potencia", "expresion": "(-10)² ÷ (-5)", "valor": -20, "signo": "-", "dificultad": 2, "explicacion": "(-10)² es 100. 100 ÷ -5 = -20. Positivo dividido negativo es negativo." },
    { "id": 19, "curso_minimo": "2do", "tipo": "division_potencia", "expresion": "(-4)³ ÷ (+8)", "valor": -8, "signo": "-", "dificultad": 2, "explicacion": "(-4)³ es -64. -64 ÷ 8 = -8. Negativo dividido positivo es negativo." },
    { "id": 20, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(100)", "valor": 10, "signo": "+", "dificultad": 3, "opciones": ["10", "-10", "50", "No real"], "explicacion": "La raíz cuadrada de 100 es 10." },
    { "id": 21, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(-100)", "valor": null, "signo": "invalido", "dificultad": 3, "opciones": ["10", "-10", "0", "No real"], "explicacion": "No existe la raíz cuadrada de un número negativo en el conjunto de los números reales." },
    { "id": 22, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(144)", "valor": 12, "signo": "+", "dificultad": 3, "opciones": ["12", "-12", "14", "No real"], "explicacion": "12 al cuadrado es 144, por lo tanto su raíz es 12." },
    { "id": 23, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(-25)", "valor": null, "signo": "invalido", "dificultad": 3, "opciones": ["5", "-5", "2.5", "No real"], "explicacion": "No hay un número real que multiplicado por sí mismo de un resultado negativo." },
    { "id": 24, "curso_minimo": "3ro", "tipo": "raiz", "expresion": "√(121)", "valor": 11, "signo": "+", "dificultad": 3, "opciones": ["11", "-11", "12", "No real"], "explicacion": "La raíz de 121 es 11 porque 11 × 11 = 121." },
    { "id": 25, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "[(-2)²]³", "valor": 64, "signo": "+", "dificultad": 3, "opciones": ["64", "-64", "32", "-32"], "explicacion": "Multiplicamos exponentes: 2 × 3 = 6. (-2)⁶ es positivo por ser exponente par." },
    { "id": 26, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "[(-2)³]²", "valor": 64, "signo": "+", "dificultad": 3, "opciones": ["64", "-64", "128", "-128"], "explicacion": "(-2)³ es -8. (-8)² es 64. El exponente final par (3×2=6) hace que el resultado sea positivo." },
    { "id": 27, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "[(-3)²]²", "valor": 81, "signo": "+", "dificultad": 3, "opciones": ["81", "-81", "27", "9"], "explicacion": "Multiplicamos exponentes: 2 × 2 = 4. (-3)⁴ es 81. Al ser exponente par, el signo es positivo." },
    { "id": 28, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "[(-1)⁵]³", "valor": -1, "signo": "-", "dificultad": 3, "opciones": ["1", "-1", "0", "-15"], "explicacion": "Multiplicamos exponentes: 5 × 3 = 15. (-1)¹⁵ es negativo porque el exponente es impar." },
    { "id": 29, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "[(-2)²]⁴", "valor": 256, "signo": "+", "dificultad": 3, "opciones": ["256", "-256", "128", "64"], "explicacion": "Exponentes multiplicados: 2 × 4 = 8. (-2)⁸ es 256. El signo es positivo por el exponente par." },
    { "id": 30, "curso_minimo": "2do", "tipo": "combinado", "expresion": "[(-2) × (-5)] ÷ (-2)", "valor": -5, "signo": "-", "dificultad": 2, "explicacion": "Primero el corchete: (-2)×(-5)=10. Luego 10÷(-2)=-5." },
    { "id": 31, "curso_minimo": "2do", "tipo": "combinado", "expresion": "(-18) ÷ [(-6) + (+3)]", "valor": 6, "signo": "+", "dificultad": 2, "explicacion": "Dentro del corchete: -6+3=-3. Luego -18÷(-3)=6." },
    { "id": 32, "curso_minimo": "2do", "tipo": "combinado", "expresion": "[(-3) × (+2)]²", "valor": 36, "signo": "+", "dificultad": 2, "explicacion": "Dentro del corchete: -6. Luego (-6)²=36." },
    { "id": 33, "curso_minimo": "2do", "tipo": "combinado", "expresion": "[(-15) ÷ (-3)] × (-4)", "valor": -20, "signo": "-", "dificultad": 2, "explicacion": "Dentro del corchete: 5. Luego 5×(-4)=-20." },
    { "id": 34, "curso_minimo": "2do", "tipo": "combinado", "expresion": "(-3) × [(-12) ÷ (+4)]", "valor": 9, "signo": "+", "dificultad": 2, "explicacion": "Dentro del corchete: -3. Luego -3×(-3)=9." },
    { "id": 35, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "{(-3)² + [(-5) × (+2)]} × (-4)", "valor": 4, "signo": "+", "dificultad": 3, "opciones": ["4", "-4", "40", "-40"], "explicacion": "{9 + (-10)} × (-4) = -1 × (-4) = 4." },
    { "id": 36, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "√{[(-6)² - (+11)]}", "valor": 5, "signo": "+", "dificultad": 3, "opciones": ["5", "-5", "25", "No real"], "explicacion": "√{36 - 11} = √25 = 5." },
    { "id": 37, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "[(-2)⁴ ÷ (-8)] + {(-3)³ ÷ (+9)}", "valor": -5, "signo": "-", "dificultad": 3, "opciones": ["-5", "5", "-11", "11"], "explicacion": "[16 ÷ (-8)] + {-27 ÷ 9} = -2 + (-3) = -5." },
    { "id": 38, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "{(-1)⁵ × [(-2)³]²} ÷ (-16)", "valor": 4, "signo": "+", "dificultad": 3, "opciones": ["4", "-4", "8", "-8"], "explicacion": "{-1 × 64} ÷ (-16) = -64 ÷ (-16) = 4." },
    { "id": 39, "curso_minimo": "3ro", "tipo": "combinado", "expresion": "√{[(-8)² ÷ (+4)] - 25}", "valor": null, "signo": "invalido", "dificultad": 3, "opciones": ["3", "-3", "0", "No real"], "explicacion": "√{16 - 25} = √(-9). No es un número real." }
  ]
}
